@inproceedings{vg2024adversarial,
  title        = {Adversarial Manipulation in Autonomous LLM Agents:
                   A Taxonomy and Threat Model},
  author       = {VG, Jeyasurya},
  booktitle    = {Proceedings of the Workshop on Security of Machine Learning
                   (SecML) at NeurIPS},
  year         = {2024},
  url          = {},
  abstract     = {Autonomous agents built on large language models introduce a new
                   class of adversarial surface: the agent's reasoning loop itself.
                   This paper proposes a structured taxonomy of adversarial behaviors
                   in LLM agents, covering prompt injection, goal hijacking, memory
                   poisoning, and tool-call manipulation. We present a threat model
                   grounded in a Delphi expert study and validate attack scenarios
                   in an isolated lab environment.},
  selected     = {true},
  note         = {Preprint / Under Review — update with actual venue}
}

@article{vg2024otllm,
  title        = {Integrating Cyber Threat Intelligence into OT/ICS Vulnerability
                   Prioritization: A Decision Framework},
  author       = {VG, Jeyasurya},
  journal      = {Computers and Security},
  year         = {2024},
  url          = {},
  abstract     = {Operational technology environments present unique challenges for
                   vulnerability prioritization: patch windows are narrow, system
                   availability is paramount, and standard CVSS scoring fails to
                   account for ICS-specific exploitation context. This paper presents
                   a decision framework that incorporates CISA KEV advisories, ICSA
                   identifiers, APT correlation, ransomware weaponization signals, and
                   IT-OT convergence scenarios into a structured triage workflow.},
  selected     = {false},
  note         = {Preprint / Under Review — update with actual journal}
}
